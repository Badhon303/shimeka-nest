{
  "name": "shimeka-nest",
  "version": "1.0.0",
  "private": true,
  "description": "Shimeka — full-stack ecommerce platform (makeup & clothing)",
  "packageManager": "pnpm@10.27.0",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "start": "turbo run start",
    "db:generate": "pnpm --filter @shimeka/api prisma:generate",
    "db:migrate": "pnpm --filter @shimeka/api prisma:migrate",
    "db:seed": "pnpm --filter @shimeka/api prisma:seed",
    "db:studio": "pnpm --filter @shimeka/api prisma:studio"
  },
  "devDependencies": {
    "turbo": "^2.3.3",
    "typescript": "^5.7.2",
    "prettier": "^3.4.2"
  },
  "pnpm": {
    "onlyBuiltDependencies": [
      "@prisma/client",
      "@prisma/engines",
      "prisma",
      "argon2",
      "@nestjs/core"
    ]
  }
}
