# ---- Database (PostgreSQL) ----
DATABASE_URL="postgresql://user:password@host:5432/shimeka-nest-db?schema=public"

# ---- Redis (used for throttler/cache; optional in dev) ----
REDIS_URL="redis://:password@host:6380"

# ---- App ----
PORT=4000
NODE_ENV=development
CORS_ORIGINS="http://localhost:3000,http://localhost:3001"

# ---- JWT ----
# Use separate secrets for customer vs admin token contexts.
JWT_CUSTOMER_ACCESS_SECRET="change-me-customer-access"
JWT_CUSTOMER_REFRESH_SECRET="change-me-customer-refresh"
JWT_ADMIN_ACCESS_SECRET="change-me-admin-access"
JWT_ADMIN_REFRESH_SECRET="change-me-admin-refresh"
JWT_ACCESS_TTL="15m"
JWT_REFRESH_TTL="7d"

# ---- Uploads ----
UPLOAD_DRIVER="local"           # local | s3 (s3 not implemented in phase 1)
UPLOAD_LOCAL_DIR="uploads"
UPLOAD_PUBLIC_BASE_URL="http://localhost:4000/uploads"

# ---- Seed admin (used by prisma/seed.ts) ----
SEED_ADMIN_EMAIL="admin@shimeka.com"
SEED_ADMIN_PASSWORD="Admin@12345"
